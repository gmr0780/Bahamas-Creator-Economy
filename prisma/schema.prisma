generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id             String   @id @default(cuid())
  fullName       String
  email          String   @unique
  phone          String
  platform       String
  handle         String
  followers      String
  niche          String
  monetization   String
  topics         String[]
  status         String   @default("pending")
  source         String   @default("website")
  checkedIn      Boolean  @default(false)
  checkedInAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String   @default("")
  userAgent String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model Guide {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String   @default("")
  icon        String   @default("")
  order       Int      @default(0)
  published   Boolean  @default(false)
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailPixel {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  opens     EmailPixelOpen[]
  createdAt DateTime @default(now())
}

model EmailPixelOpen {
  id        String     @id @default(cuid())
  pixelId   String
  pixel     EmailPixel @relation(fields: [pixelId], references: [id])
  ip        String     @default("")
  userAgent String     @default("")
  createdAt DateTime   @default(now())

  @@index([pixelId])
}

model XMasterclassRegistration {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  phone     String
  island    String
  xHandle   String
  createdAt DateTime @default(now())
}
